<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — devhandbook.io</title>
  <meta name="description" content="{{ description }}">
  <link rel="canonical" href="https://devhandbook.io{{ page.url }}">
  <link rel="stylesheet" href="/apple-redesign.css">
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; margin: 0; background: #fff; color: #1d1d1f; }
    .nav { max-width: 900px; margin: 0 auto; padding: 20px 24px; display: flex; justify-content: space-between; align-items: center; }
    .nav a { color: #1d1d1f; text-decoration: none; font-size: 14px; }
    .nav a:hover { color: #0071e3; }
    .nav .logo { font-weight: 600; font-size: 16px; }
    .nav-links { display: flex; gap: 24px; }
    .content { max-width: 900px; margin: 0 auto; padding: 0 24px 60px; }
    @media (prefers-color-scheme: dark) {
      body { background: #000; color: #f5f5f7; }
      .nav a { color: #f5f5f7; }
    }
  </style>
</head>
<body>
  <nav class="nav">
    <a href="/" class="logo">devhandbook.io</a>
    <div class="nav-links">
      <a href="/">Tools</a>
      <a href="/blog/">Blog</a>
    </div>
  </nav>
  <main class="content">
    {{ content | safe }}
  </main>
</body>
</html>
