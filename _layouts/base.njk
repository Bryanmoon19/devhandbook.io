<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — devhandbook.io</title>
  <meta name="description" content="{{ description }}">
  <link rel="canonical" href="https://devhandbook.io{{ page.url }}">
  <script>
    (function() {
      var d = document.documentElement;
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        d.classList.add('dark');
      }
    })();
  </script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #fbfbfd;
      --text: #1d1d1f;
      --text-2: #6e6e73;
      --accent: #0071e3;
      --accent-hover: #0077ed;
      --border: rgba(0,0,0,0.07);
      --surface: rgba(255,255,255,0.82);
      --font: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', sans-serif;
    }
    html.dark {
      --bg: #000;
      --text: #f5f5f7;
      --text-2: #98989d;
      --accent: #2997ff;
      --accent-hover: #4da8ff;
      --border: rgba(255,255,255,0.08);
      --surface: rgba(0,0,0,0.82);
    }
    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
    }
    /* ── Sticky blur nav ── */
    .site-nav {
      position: sticky;
      top: 0;
      z-index: 50;
      background: var(--surface);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border-bottom: 1px solid var(--border);
    }
    .site-nav__inner {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 24px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .site-nav a {
      color: var(--text);
      text-decoration: none;
      font-size: 14px;
      transition: color 0.2s;
    }
    .site-nav a:hover { color: var(--accent); }
    .site-nav .logo { font-weight: 600; font-size: 15px; }
    .nav-links { display: flex; gap: 24px; }
    /* ── Content ── */
    .site-content {
      max-width: 900px;
      margin: 0 auto;
      padding: 48px 24px 80px;
    }
    @media (max-width: 600px) {
      .site-nav__inner { padding: 0 16px; }
      .site-content { padding: 32px 16px 60px; }
    }
  </style>
</head>
<body>
  <nav class="site-nav">
    <div class="site-nav__inner">
      <a href="/" class="logo">devhandbook.io</a>
      <div class="nav-links">
        <a href="/">Tools</a>
        <a href="/blog/">Blog</a>
      </div>
    </div>
  </nav>
  <main class="site-content">
    {{ content | safe }}
  </main>
</body>
</html>
