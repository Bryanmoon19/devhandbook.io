---
layout: base.njk
---
<style>
  .post-header { margin-bottom: 40px; }
  .post-header h1 { font-size: 2rem; font-weight: 700; line-height: 1.2; margin: 0 0 12px; }
  .post-meta { font-size: 14px; color: #6e6e73; }
  .post-body { font-size: 17px; line-height: 1.7; }
  .post-body h2 { font-size: 1.4rem; font-weight: 600; margin-top: 40px; }
  .post-body h3 { font-size: 1.1rem; font-weight: 600; margin-top: 28px; }
  .post-body code { background: #f5f5f7; padding: 2px 6px; border-radius: 4px; font-size: 14px; }
  .post-body pre { background: #1d1d1f; color: #f5f5f7; padding: 20px; border-radius: 10px; overflow-x: auto; }
  .post-body pre code { background: none; padding: 0; color: inherit; font-size: 14px; }
  .post-body a { color: #0071e3; }
  .back-link { display: inline-block; margin-bottom: 32px; font-size: 14px; color: #0071e3; text-decoration: none; }
  .back-link:hover { text-decoration: underline; }
  @media (prefers-color-scheme: dark) {
    .post-body code { background: #1d1d1f; color: #f5f5f7; }
    .post-meta { color: #a1a1a6; }
  }
</style>

<a href="/blog/" class="back-link">← All posts</a>
<div class="post-header">
  <h1>{{ title }}</h1>
  <div class="post-meta">{{ date | dateFormat }}</div>
</div>
<div class="post-body">
  {{ content | safe }}
</div>
