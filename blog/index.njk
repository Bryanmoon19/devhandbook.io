---
layout: base.njk
title: Blog
description: Developer tutorials, homelab guides, and tools walkthroughs from devhandbook.io
---
<style>
  .blog-hero { margin-bottom: 40px; }
  .blog-hero h1 {
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 10px;
    color: var(--text);
  }
  .blog-hero p { font-size: 17px; color: var(--text-2); }

  .post-grid { display: flex; flex-direction: column; gap: 16px; }

  .post-card {
    display: block;
    text-decoration: none;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    transition: box-shadow 0.25s, transform 0.25s;
  }
  .post-card:hover {
    box-shadow: 0 12px 40px rgba(0,0,0,0.1), 0 2px 8px rgba(0,0,0,0.06);
    transform: translateY(-2px);
  }
  html.dark .post-card { background: rgba(28,28,30,0.85); }

  .post-meta { font-size: 13px; color: var(--text-2); margin-bottom: 10px; display: flex; gap: 12px; flex-wrap: wrap; }
  .post-tag {
    background: rgba(0,113,227,0.08);
    color: var(--accent);
    border-radius: 980px;
    padding: 2px 10px;
    font-size: 12px;
    font-weight: 500;
  }
  html.dark .post-tag { background: rgba(41,151,255,0.12); }

  .post-card h2 {
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 8px;
    line-height: 1.3;
  }
  .post-card:hover h2 { color: var(--accent); }
  .post-card p { font-size: 15px; color: var(--text-2); line-height: 1.6; }

  @media (max-width: 600px) {
    .post-card { padding: 18px; }
    .blog-hero h1 { font-size: 1.8rem; }
  }
</style>

<div class="blog-hero">
  <h1>Blog</h1>
  <p>Dev tutorials, homelab guides, and tool walkthroughs.</p>
</div>

<div class="post-grid">
  {% for post in collections.blog %}
  <a class="post-card" href="{{ post.url }}">
    <div class="post-meta">
      <span>{{ post.data.date | dateFormat }}</span>
      {% if post.data.tags and post.data.tags.length %}
        {% for tag in post.data.tags %}
          <span class="post-tag">{{ tag }}</span>
        {% endfor %}
      {% endif %}
    </div>
    <h2>{{ post.data.title }}</h2>
    <p>{{ post.data.description }}</p>
  </a>
  {% endfor %}
</div>
